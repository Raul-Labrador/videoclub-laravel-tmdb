    background-color: var(--copy-table-bg) !important;
    color: var(--copy-light) !important;
    border: 1px solid #444;
}

.modal-header, .modal-footer {
    border-color: #444 !important;
}

.modal-title {
    color: var(--copy-accent) !important;
}
