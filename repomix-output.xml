            'fecha_sal'  => 'fecha de salida (alquiler)',
            'fecha_dev'  => 'fecha de devolución',
            'precio'     => 'precio del alquiler',
        ];
    }

    function authorize(): bool {
        return true;
    }

    function messages(): array {
        // Variables para mensajes repetitivos
