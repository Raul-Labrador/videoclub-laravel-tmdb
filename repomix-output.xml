}
.dashboard-card.red:hover {
    border-color: var(--red);
    box-shadow: 0 4px 20px rgba(230, 57, 70, 0.2);
}
.dashboard-card.cyan:hover {
    border-color: var(--cyan);
    box-shadow: 0 4px 20px var(--cyan-dim);
}
.dashboard-card.green:hover {
    border-color: var(--green);
    box-shadow: 0 4px 20px var(--green-dim);
}

.dashboard-card-icon {
    font-size: 1.75rem;
    margin-bottom: 0.25rem;
}
.dashboard-card-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 1px;
    color: var(--text);
}
.dashboard-card.gold .dashboard-card-title {
    color: var(--gold);
}
.dashboard-card.red .dashboard-card-title {
    color: var(--red);
}
.dashboard-card.cyan .dashboard-card-title {
    color: var(--cyan);
}
.dashboard-card.green .dashboard-card-title {
    color: var(--green);
}

.dashboard-card-desc {
    font-size: 0.83rem;
    color: var(--muted);
    line-height: 1.5;
}

/* ── FOOTER ──────────────────────────────────────────────── */
footer {
    margin-top: 4rem;
    padding: 1.5rem 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: center;
    align-items: center;
}

footer span {
